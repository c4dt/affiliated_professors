# Copy to .env for local runs:  cp .env.example .env  (then fill in secrets).
# .env is gitignored. In GitHub Actions these come from repo secrets/variables.

# --- LLM (provider-agnostic) ---
# Provider-prefixed model string, or a bare model name when LLM_BASE_URL is set.
LLM_MODEL=anthropic:claude-sonnet-4-6
# Optional: point at any OpenAI-compatible / self-hosted endpoint.
# LLM_BASE_URL=https://your-endpoint/v1
# API key; mapped to the provider's env var (or used as the base-url key).
LLM_API_KEY=

# --- Sources ---
FIRECRAWL_API_KEY=
# Optional; higher GitHub rate limit (auto-provided in Actions).
# GITHUB_TOKEN=

# --- Matrix announcement (room must be UNENCRYPTED) ---
MATRIX_HOMESERVER_URL=https://matrix.example.org
MATRIX_ROOM_ID=!roomid:example.org
# Either a ready access token...
# MATRIX_ACCESS_TOKEN=
# ...or password login:
MATRIX_LOGIN=
MATRIX_PASS=
# Set true to also announce non-significant (heartbeat) updates.
# MATRIX_POST_MINOR=false

# --- Profile links (optional; auto-set in GitHub Actions) ---
# Override the base URL used in the "Full profile" link.
# PROFILE_BASE_URL=https://github.com/c4dt/affiliated_professors/blob/main
